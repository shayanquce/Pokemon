{
  "name": "luminary-game",
  "productName": "Luminary - Echoes of the Forgotten Age",
  "version": "0.15.0",
  "description": "Luminary: Echoes of the Forgotten Age — a monster-taming RPG built with Electron + Phaser 3",
  "main": "main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "electron .",
    "save-smoke": "electron . --save-smoke",
    "engine-test": "node scripts/engine-test.mjs",
    "playtest-game": "electron . --remote-debugging-port=9223",
    "playtest": "node scripts/playtest-cdp.mjs",
    "fix-electron": "node node_modules/electron/install.js"
  },
  "license": "MIT",
  "dependencies": {
    "electron": "^42.4.0",
    "electron-store": "^11.0.2",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "electron-builder": "^26.15.2"
  }
}
